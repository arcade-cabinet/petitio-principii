{
  "name": "petitio-principii",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "build-corpus": "tsx scripts/build-corpus.ts",
    "verify-corpus": "tsx scripts/verify-corpus.ts",
    "check-bundle": "tsx scripts/check-bundle-size.ts",
    "prebuild": "pnpm build-corpus",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "verify": "pnpm verify-corpus && pnpm check && pnpm typecheck && pnpm test && vite build && pnpm check-bundle"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@capacitor/cli": "^8.3.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/tracery-grammar": "^2.7.4",
    "@types/yuka": "^0.7.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/vt323": "^5.2.7",
    "@fontsource/yesteryear": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "howler": "^2.2.4",
    "i18next": "^26.0.6",
    "i18next-resources-to-backend": "^1.2.1",
    "koota": "^0.6.6",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "rita": "^3.2.11",
    "tailwind-merge": "^3.5.0",
    "tracery-grammar": "^2.8.4",
    "yuka": "^0.7.8"
  },
  "packageManager": "pnpm@10.33.0"
}
